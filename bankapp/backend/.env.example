NODE_ENV=development
PORT=3001
API_VERSION=v1

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bankdb
DB_USER=bankuser
DB_PASSWORD=ChangeMe_Strong_Password_123!
DB_POOL_MAX=20

# JWT  (générer avec: openssl rand -base64 64)
JWT_SECRET=CHANGE_THIS_TO_64_CHAR_RANDOM_STRING_openssl_rand_base64_64
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=CHANGE_THIS_TO_ANOTHER_64_CHAR_RANDOM_STRING
JWT_REFRESH_EXPIRES_IN=7d

# Sécurité
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=5

# CORS (séparés par virgule)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost

# Logs
LOG_LEVEL=info
LOG_DIR=./logs
